# Optional: override the Supabase project at build time.
# The app ships with public-safe anon defaults in src/lib/config.ts,
# so this file is only needed to point at a different project.
# Copy to .env.local (gitignored) or set these as GitHub Action secrets.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_KEY=your-anon-public-key
